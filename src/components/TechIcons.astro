const { tools = [], filterMode = false } = Astro.props;
---

{filterMode ? (
  <div class="tech-icon-row">
    {tools.map((tool: string) => {
      const icon = ICONS[tool] ?? null;
      return (
        <button
          class="ti-btn tool-tag--filter"
          data-filter-tool={tool}
          aria-pressed="false"
          type="button"
          title={tool}
          aria-label={tool}
        >
          {icon ? (
            <span class="ti-icon" set:html={icon.svg} aria-hidden="true" />
          ) : (
            <span class="ti-fallback" aria-hidden="true">{tool.slice(0,2)}</span>
          )}
          <span class="ti-tooltip" role="tooltip">{tool}</span>
        </button>
      );
    })}
  </div>
) : (
  <div class="tech-icon-row">
    {tools.map((tool: string) => {
      const icon = ICONS[tool] ?? null;
      return (
        <span class="ti-chip" title={tool}>
          {icon ? (
            <span class="ti-icon" set:html={icon.svg} aria-hidden="true" />
          ) : (
            <span class="ti-fallback" aria-hidden="true">{tool.slice(0,2)}</span>
          )}
          <span class="ti-tooltip" role="tooltip">{tool}</span>
        </span>
      );
    })}
  </div>
)}
