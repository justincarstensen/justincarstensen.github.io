---
type IconDef = { src: string; bg?: string };

// Official brand logos, served live from Simple Icons (https://simpleicons.org)
// and Devicon (https://devicon.dev) CDNs — not custom-drawn artwork.
const ICONS: Record<string, IconDef> = {
  /* ── Web ── */
  "HTML": { src: "https://cdn.simpleicons.org/html5" },
  "CSS": { src: "https://cdn.simpleicons.org/css" },
  "SCSS": { src: "https://cdn.simpleicons.org/sass" },
  "JavaScript": { src: "https://cdn.simpleicons.org/javascript" },
  "TypeScript": { src: "https://cdn.simpleicons.org/typescript" },
  /* ── Frameworks / Libraries ── */
  "Next.js": { src: "https://cdn.simpleicons.org/nextdotjs" },
  "React": { src: "https://cdn.simpleicons.org/react" },
  "Vue": { src: "https://cdn.simpleicons.org/vuedotjs" },
  "Svelte": { src: "https://cdn.simpleicons.org/svelte" },
  "Astro": { src: "https://cdn.simpleicons.org/astro" },
  "Vite": { src: "https://cdn.simpleicons.org/vite" },
  "MUI": { src: "https://cdn.simpleicons.org/mui" },
  "Tailwind": { src: "https://cdn.simpleicons.org/tailwindcss" },
  "Drizzle ORM": { src: "https://cdn.simpleicons.org/drizzle" },
  "TanStack Query": { src: "https://cdn.simpleicons.org/tanstack" },
  "Three.js": { src: "https://cdn.simpleicons.org/threedotjs" },
  "p5.js": { src: "https://cdn.simpleicons.org/p5dotjs" },
  /* ── Runtime / Data / Backend ── */
  "Node.js": { src: "https://cdn.simpleicons.org/nodedotjs" },
  "Deno": { src: "https://cdn.simpleicons.org/deno" },
  "SQLite": { src: "https://cdn.simpleicons.org/sqlite" },
  "Nunjucks": { src: "https://cdn.simpleicons.org/nunjucks" },
  "Docker": { src: "https://cdn.simpleicons.org/docker" },
  "Webpack": { src: "https://cdn.simpleicons.org/webpack" },
  "Python": { src: "https://cdn.simpleicons.org/python" },
  "Java": { src: "https://cdn.simpleicons.org/openjdk" },
  "Kotlin": { src: "https://cdn.simpleicons.org/kotlin" },
  "Swift": { src: "https://cdn.simpleicons.org/swift" },
  /* ── Other languages without Simple Icons entries (Devicon fallback) ── */
  "C#": { src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/csharp/csharp-original.svg" },
  /* GDScript has no dedicated brand icon anywhere — reusing the Godot logo just
     duplicates it and confuses the two, so this is intentionally left without
     an icon and falls back to its initials. */
  /* ── Tools ── */
  "Git": { src: "https://cdn.simpleicons.org/git" },
  "Figma": { src: "https://cdn.simpleicons.org/figma" },
  /* ── 3D / Game ── */
  "Blender": { src: "https://cdn.simpleicons.org/blender" },
  "Unity": { src: "https://cdn.simpleicons.org/unity" },
  "Godot": { src: "https://cdn.simpleicons.org/godotengine" },
  "Aseprite": { src: "https://cdn.simpleicons.org/aseprite" },
  /* OpenXR has no working hosted icon (the old Devicon path 404s and no
     Simple Icons entry exists) — falls back to initials rather than a
     broken-image placeholder. */
  /* ── Adobe ──
     Simple Icons removed all Adobe product icons site-wide after a trademark
     takedown request (cdn.simpleicons.org/adobe* now 404s), and Devicon is
     missing InDesign entirely. Using the gilbarbara/logos set instead (CC0,
     served via raw.githubusercontent.com) — it has all six as full-color
     app-icon-style SVGs, including InDesign. */
  "Adobe Photoshop": { src: "https://raw.githubusercontent.com/gilbarbara/logos/main/logos/adobe-photoshop.svg" },
  "Adobe Illustrator": { src: "https://raw.githubusercontent.com/gilbarbara/logos/main/logos/adobe-illustrator.svg" },
  "Adobe After Effects": { src: "https://raw.githubusercontent.com/gilbarbara/logos/main/logos/adobe-after-effects.svg" },
  "Adobe Premiere": { src: "https://raw.githubusercontent.com/gilbarbara/logos/main/logos/adobe-premiere.svg" },
  "Adobe InDesign": { src: "https://raw.githubusercontent.com/gilbarbara/logos/main/logos/adobe-indesign.svg" },
  "Adobe XD": { src: "https://raw.githubusercontent.com/gilbarbara/logos/main/logos/adobe-xd.svg" },
};

const { tools = [], filterMode = false } = Astro.props;
---

{filterMode ? (
  <div class="tech-icon-row">
    {tools.map((tool: string) => {
      const icon = ICONS[tool] ?? null;
      return (
        <button
          class="ti-btn tool-tag--filter"
          data-filter-tool={tool}
          aria-pressed="false"
          type="button"
          title={tool}
          aria-label={tool}
        >
          {icon ? (
            <img class="ti-icon" src={icon.src} alt={tool} loading="lazy" width="18" height="18" aria-hidden="true" />
          ) : (
            <span class="ti-fallback" aria-hidden="true">{tool.slice(0,2)}</span>
          )}
          <span class="ti-tooltip" role="tooltip">{tool}</span>
        </button>
      );
    })}
  </div>
) : (
  <div class="tech-icon-row">
    {tools.map((tool: string) => {
      const icon = ICONS[tool] ?? null;
      return (
        <span class="ti-chip" title={tool}>
          {icon ? (
            <img class="ti-icon" src={icon.src} alt={tool} loading="lazy" width="18" height="18" aria-hidden="true" />
          ) : (
            <span class="ti-fallback" aria-hidden="true">{tool.slice(0,2)}</span>
          )}
          <span class="ti-tooltip" role="tooltip">{tool}</span>
        </span>
      );
    })}
  </div>
)}