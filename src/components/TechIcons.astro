const { tools = [] } = Astro.props;
---

<div class="tech-row">
  {tools.map((tool: string) => {
    const icon = ICONS[tool] ?? { color: "#888", svg: `<svg viewBox="0 0 16 16" width="16" height="16"><circle cx="8" cy="8" r="6" fill="currentColor" opacity=".3"/></svg>` };
    return (
      <span class="ti" style={`--c:${icon.color}`} title={tool}>
        <span class="ti-icon" set:html={icon.svg} />
        <span class="ti-label">{tool}</span>
      </span>
    );
  })}
</div>

<style>
.tech-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.ti {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 10px 5px 7px;
  border-radius: 7px;
  background: var(--bg-subtle);
  border: 1px solid var(--line);
  color: var(--c);
  cursor: default;
  transition: background var(--transition), border-color var(--transition), transform var(--transition);
}
.ti:hover {
  background: var(--bg-card);
  border-color: var(--c);
  transform: translateY(-1px);
}
.ti-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.ti-label {
  font-size: 12px;
  font-weight: 500;
  color: var(--ink-2);
  white-space: nowrap;
}
</style>
