---
const { images = [], videos = [], projectId = "default" } = Astro.props;
const hasMedia = images.length > 0 || videos.length > 0;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const allMedia = [
  ...images.map((src: string, i: number) => ({ type: "image", src, index: i })),
  ...videos.map((src: string, i: number) => ({ type: "video", src, index: images.length + i })),
];
const totalCount = allMedia.length;
---

{hasMedia && (
  <div class="gallery-outer">

    <div
      class="gallery-track"
      id={`track-${projectId}`}
      data-gallery={projectId}
      data-total={totalCount}
    >
      {allMedia.map((item, i) => (
        <div
          class="gitem"
          data-type={item.type}
          data-src={`${base}/${item.src.replace(/^\//, "")}`}
          data-index={i}
          tabindex="0"
          role="button"
          aria-label={item.type === "image" ? `Bild ${i + 1} von ${totalCount} öffnen` : `Video ${i + 1} von ${totalCount} öffnen`}
        >
          {item.type === "image" ? (
            <img
              src={`${base}/${item.src.replace(/^\//, "")}`}
              alt={`Projektbild ${i + 1}`}
              loading={i === 0 ? "eager" : "lazy"}
              draggable="false"
            />
          ) : (
            <div class="gitem-video-wrap">
              <video
                src={`${base}/${item.src.replace(/^\//, "")}`}
                muted
                preload="metadata"
                playsinline
              />
              <span class="gitem-play-icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><polygon points="6,3 20,12 6,21"/></svg>
              </span>
            </div>
          )}
        </div>
      ))}
    </div>

    {totalCount > 1 && (
      <div class="gallery-nav" data-nav={projectId}>
        {allMedia.map((_, i) => (
          <button
            class="gnav-dot"
            data-dot={projectId}
            data-dot-idx={i}
            type="button"
            aria-label={`Element ${i + 1}`}
          />
        ))}
      </div>
    )}

  </div>
)}

<!-- Lightbox -->
{hasMedia && (
  <div class="lb" id={`lb-${projectId}`} hidden>
    <div class="lb-bg" data-lb-bg={projectId}></div>
    <button class="lb-x" data-lb-x={projectId} type="button" aria-label="Schließen">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <div class="lb-center">
      <img class="lb-img" src="" alt="" />
      <video class="lb-vid" controls playsinline></video>
    </div>
  </div>
)}

<style>
/* ── Gallery wrapper ── */
.gallery-outer {
  margin-top: 40px;
  padding-bottom: clamp(28px, 4vw, 48px);
  overflow: hidden;
}

/* ── Scroll track ── */
.gallery-track {
  display: flex;
  align-items: stretch;
  gap: 10px;
  overflow-x: scroll;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
  padding-inline: calc((100% - min(58vw, 680px)) / 2);
}
.gallery-track::-webkit-scrollbar { display: none; }

/* ── Items — etwas kleiner als vorher ── */
.gitem {
  flex-shrink: 0;
  width: min(58vw, 680px);
  height: clamp(160px, 32vw, 400px);
  border-radius: 4px;
  overflow: hidden;
  background: var(--bg-subtle);
  cursor: pointer;
  scroll-snap-align: center;
  position: relative;
  outline: none;
  transition: opacity 0.2s;
}
.gitem:hover { opacity: 0.88; }
.gitem:focus-visible { outline: 2px solid var(--ink-1, #111); outline-offset: 3px; }

.gitem img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  pointer-events: none;
  user-select: none;
}

.gitem-video-wrap {
  position: relative;
  width: 100%;
  height: 100%;
}
.gitem-video-wrap video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  pointer-events: none;
}
.gitem-play-icon {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.22);
}
/* Play-Icon Kreis */
.gitem-play-icon::before {
  content: "";
  position: absolute;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: rgba(255,255,255,0.18);
  border: 1.5px solid rgba(255,255,255,0.5);
}
.gitem-play-icon svg {
  position: relative;
  z-index: 1;
  margin-left: 3px;
}

/* ── Nav — Punktlinie, zentriert ── */
.gallery-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding-top: 16px;
}

.gnav-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  border: none;
  background: var(--ink-3, #aaa);
  cursor: pointer;
  padding: 0;
  transition: background 0.2s, transform 0.2s;
  flex-shrink: 0;
}
.gnav-dot[data-active] {
  background: var(--ink-1, #111);
  transform: scale(1.5);
}
.gnav-dot:focus-visible {
  outline: 2px solid var(--ink-1, #111);
  outline-offset: 2px;
}

/* ── Lightbox ── */
.lb {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 99999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.lb[hidden] { display: none !important; }

.lb-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  cursor: pointer;
}

/* Close — reduziert, zur Bewerbung passend */
.lb-x {
  position: fixed;
  top: 20px;
  right: 24px;
  z-index: 2;
  width: 40px;
  height: 40px;
  border-radius: 2px;
  border: 1px solid rgba(255,255,255,0.35);
  background: rgba(0,0,0,0.35);
  color: rgba(255,255,255,0.9);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s, border-color 0.15s;
  letter-spacing: 0.05em;
}
.lb-x:hover { background: rgba(0,0,0,0.6); border-color: rgba(255,255,255,0.7); }
.lb-x:focus-visible { outline: 2px solid white; outline-offset: 3px; }

/* Content frame */
.lb-center {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  max-width: min(96vw, 1400px);
  max-height: 94vh;
  pointer-events: none;
}

/* Lightbox-Bild — größer als zuvor */
.lb-img {
  display: block;
  max-width: min(94vw, 1360px);
  max-height: 92vh;
  border-radius: 2px;
  object-fit: contain;
  pointer-events: none;
}
.lb-vid {
  display: block;
  max-width: min(94vw, 1360px);
  max-height: 92vh;
  border-radius: 2px;
  background: #000;
  pointer-events: auto;
}

.lb-img[data-hide], .lb-vid[data-hide] { display: none; }

@media (max-width: 640px) {
  .gitem { width: 80vw; height: clamp(140px, 48vw, 280px); }
  .lb-x { top: 12px; right: 12px; width: 36px; height: 36px; }
}
</style>

<script>
(function () {
  document.querySelectorAll<HTMLElement>('.gallery-track').forEach(track => {
    const galleryId = track.dataset.gallery!;
    const total     = parseInt(track.dataset.total || '1');
    const items     = Array.from(track.querySelectorAll<HTMLElement>('.gitem'));

    const dots  = Array.from(document.querySelectorAll<HTMLButtonElement>(`[data-dot="${galleryId}"]`));

    const lb    = document.getElementById(`lb-${galleryId}`)!;
    const lbBg  = lb.querySelector<HTMLElement>('.lb-bg')!;
    const lbX   = lb.querySelector<HTMLButtonElement>('.lb-x')!;
    const lbImg = lb.querySelector<HTMLImageElement>('.lb-img')!;
    const lbVid = lb.querySelector<HTMLVideoElement>('.lb-vid')!;

    let current = 0;

    // ── Scroll to item (centred) ──────────────────────────────────────────
    function scrollToIdx(idx: number, instant = false) {
      const item = items[idx];
      if (!item) return;
      const left = item.offsetLeft - (track.clientWidth - item.offsetWidth) / 2;
      track.scrollTo({ left, behavior: instant ? 'instant' : 'smooth' });
    }

    function updateUI() {
      dots.forEach((d, i) => {
        if (i === current) d.setAttribute('data-active', '');
        else d.removeAttribute('data-active');
      });
    }

    function nearestIdx(): number {
      const centre = track.scrollLeft + track.clientWidth / 2;
      let best = 0, dist = Infinity;
      items.forEach((item, i) => {
        const d = Math.abs(item.offsetLeft + item.offsetWidth / 2 - centre);
        if (d < dist) { dist = d; best = i; }
      });
      return best;
    }

    // ── Lightbox ──────────────────────────────────────────────────────────
    function openLB(item: HTMLElement) {
      const type = item.dataset.type!;
      const src  = item.dataset.src!;

      lbVid.pause?.();
      lbVid.removeAttribute('src');
      lbImg.src = '';

      if (type === 'image') {
        lbImg.src = src;
        lbImg.alt = 'Projektbild';
        lbImg.removeAttribute('data-hide');
        lbVid.setAttribute('data-hide', '');
      } else {
        lbVid.src = src;
        lbVid.load();
        lbVid.removeAttribute('data-hide');
        lbImg.setAttribute('data-hide', '');
      }

      if (lb.parentElement !== document.body) {
        document.body.appendChild(lb);
      }

      const scrollY = window.scrollY;
      lb.dataset.scrollY = String(scrollY);
      document.documentElement.style.overflow = 'hidden';
      document.body.style.overflow = 'hidden';

      lb.hidden = false;
      setTimeout(() => lbX.focus(), 30);
    }

    function closeLB() {
      if (lb.hidden) return;
      const scrollY = parseInt(lb.dataset.scrollY || '0');
      document.documentElement.style.overflow = '';
      document.body.style.overflow = '';
      window.scrollTo(0, scrollY);
      lb.hidden = true;
      lbVid.pause?.();
      lbVid.removeAttribute('src');
      lbImg.src = '';
    }

    lbX.addEventListener('click', closeLB);
    lbBg.addEventListener('click', closeLB);
    document.addEventListener('keydown', e => {
      if (!lb.hidden && e.key === 'Escape') closeLB();
    });

    // ── Dot clicks ────────────────────────────────────────────────────────
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        current = i;
        scrollToIdx(current);
        updateUI();
      });
    });

    // ── Item clicks ───────────────────────────────────────────────────────
    items.forEach((item, i) => {
      item.addEventListener('click', () => {
        if (i === current) {
          openLB(item);
        } else {
          current = i;
          scrollToIdx(current);
          updateUI();
        }
      });
      item.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); item.click(); }
      });
    });

    // Sync from native scroll
    let tid: ReturnType<typeof setTimeout>;
    track.addEventListener('scroll', () => {
      clearTimeout(tid);
      tid = setTimeout(() => {
        const idx = nearestIdx();
        if (idx !== current) { current = idx; updateUI(); }
      }, 100);
    }, { passive: true });

    // Touch swipe
    let tx = 0;
    track.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', e => {
      const dx = e.changedTouches[0].clientX - tx;
      if (Math.abs(dx) < 40) return;
      if (dx < 0 && current < total - 1) { current++; scrollToIdx(current); updateUI(); }
      if (dx > 0 && current > 0)         { current--; scrollToIdx(current); updateUI(); }
    });

    // Init
    updateUI();
    if (document.readyState === 'complete') {
      scrollToIdx(0, true);
    } else {
      window.addEventListener('load', () => scrollToIdx(0, true), { once: true });
    }
    window.addEventListener('resize', () => scrollToIdx(current, true));

    // Erstes Frame aller Carousel-Videos laden
    track.querySelectorAll<HTMLVideoElement>('.gitem-video-wrap video').forEach(vid => {
      if (vid.readyState >= 1) {
        vid.currentTime = 0.01;
      } else {
        vid.addEventListener('loadedmetadata', () => { vid.currentTime = 0.01; }, { once: true });
      }
    });
  });
})();
</script>