---
import Gallery from "./Gallery.astro";
import TechIcons from "./TechIcons.astro";

const {
  id, title, year, season, semester, course,
  description, categories = [], tools = [],
  contributors = [], images = [], videos = [],
  index = 0,
} = Astro.props;

const projectId = `proj-${id ?? index}`;
---

<section
  class="project-section"
  data-categories={JSON.stringify(categories)}
  data-tools={JSON.stringify(tools)}
  data-course={course}
>
  <div class="ps-inner">

    <div class="ps-left">
      <!-- Meta column: prominent project info -->
      <div class="ps-meta-block">
        <div class="ps-meta-row">
          <span class="ps-meta-label" data-i18n="meta-semester">Semester</span>
          <span class="ps-meta-value ps-meta-sem">{semester}. Semester</span>
        </div>
        <div class="ps-meta-row">
          <span class="ps-meta-label" data-i18n="meta-period">Zeitraum</span>
          <span class="ps-meta-value" data-i18n-period={`proj-${id}-period`} data-season={season} data-year={year}>{season}semester {year}</span>
        </div>
        <div class="ps-meta-row">
          <span class="ps-meta-label" data-i18n="meta-course">Kurs</span>
          <span class="ps-meta-value ps-meta-course" data-i18n-course={`proj-${id}-course`}>{course}</span>
        </div>
        <div class="ps-meta-divider"></div>
        <p class="ps-desc" data-i18n-desc={`proj-${id}-desc`}>{description}</p>
      </div>
    </div>

    <div class="ps-right">
      <!-- Header: title + categories (clickable) -->
      <header class="ps-header">
        <div class="ps-num" aria-hidden="true">{String(index + 1).padStart(2, "0")}</div>
        <h2 class="ps-title" data-i18n-title={`proj-${id}-title`}>{title}</h2>
        <div class="ps-cats">
          {categories.map((c: string) => (
            <button
              class="cat-tag cat-tag--filter"
              data-filter-cat={c}
              aria-pressed="false"
              type="button"
              title={`Nach „${c}" filtern`}
            >{c}</button>
          ))}
        </div>
      </header>

      <!-- Stack + Team -->
      <div class="ps-attrs">
        {tools.length > 0 && (
          <div class="ps-attr">
            <span class="ps-attr-label" data-i18n="attr-stack">Stack</span>
            <TechIcons tools={tools} filterMode={true} />
          </div>
        )}
        {contributors.length > 0 && (
          <div class="ps-attr">
            <span class="ps-attr-label" data-i18n="attr-team">Team</span>
            <span class="ps-contrib-list">{contributors.join(", ")}</span>
          </div>
        )}
      </div>
    </div>

  </div>

  <!-- Gallery full width below -->
  {(images.length > 0 || videos.length > 0) && (
    <Gallery images={images} videos={videos} projectId={projectId} />
  )}
</section>

<script>
// Make card-level category/tool tags act as global filters
document.addEventListener('click', e => {
  const catBtn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-filter-cat]');
  const toolBtn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-filter-tool]');

  if (catBtn) {
    const val = catBtn.dataset.filterCat!;
    window.__triggerFilter?.('category', val, catBtn);
  }
  if (toolBtn) {
    const val = toolBtn.dataset.filterTool!;
    window.__triggerFilter?.('tool', val, toolBtn);
  }
});
</script>