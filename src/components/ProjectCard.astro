---
import Gallery from "./Gallery.astro";
import TechIcons from "./TechIcons.astro";

const {
  id, title, year, season, semester, course,
  description, categories = [], tools = [],
  contributors = [], images = [], videos = [],
  index = 0,
} = Astro.props;

const projectId = `proj-${id ?? index}`;
---

<section
  class="project-section"
  data-categories={JSON.stringify(categories)}
  data-tools={JSON.stringify(tools)}
>
  <div class="ps-inner">

    <div class="ps-left">
      <!-- Meta column: prominent project info -->
      <div class="ps-meta-block">
        <div class="ps-meta-row">
          <span class="ps-meta-label">Semester</span>
          <span class="ps-meta-value ps-meta-sem">{semester}. Semester</span>
        </div>
        <div class="ps-meta-row">
          <span class="ps-meta-label">Zeitraum</span>
          <span class="ps-meta-value">{season}semester {year}</span>
        </div>
        <div class="ps-meta-row">
          <span class="ps-meta-label">Kurs</span>
          <span class="ps-meta-value ps-meta-course">{course}</span>
        </div>
        <div class="ps-meta-divider"></div>
        <p class="ps-desc">{description}</p>
      </div>
    </div>

    <div class="ps-right">
      <!-- Header: title + categories (clickable) -->
      <header class="ps-header">
        <div class="ps-num" aria-hidden="true">{String(index + 1).padStart(2, "0")}</div>
        <h2 class="ps-title">{title}</h2>
        <div class="ps-cats">
          {categories.map((c: string) => (
            <button
              class="cat-tag cat-tag--filter"
              data-filter-cat={c}
              aria-pressed="false"
              type="button"
              title={`Nach „${c}" filtern`}
            >{c}</button>
          ))}
        </div>
      </header>

      <!-- Stack + Team -->
      <div class="ps-attrs">
        {tools.length > 0 && (
          <div class="ps-attr">
            <span class="ps-attr-label">Stack</span>
            <div class="ps-tools-row">
              {tools.map((t: string) => (
                <button
                  class="tool-tag tool-tag--filter"
                  data-filter-tool={t}
                  aria-pressed="false"
                  type="button"
                  title={`Nach „${t}" filtern`}
                >{t}</button>
              ))}
            </div>
          </div>
        )}
        {contributors.length > 0 && (
          <div class="ps-attr">
            <span class="ps-attr-label">Team</span>
            <span class="ps-contrib-list">{contributors.join(", ")}</span>
          </div>
        )}
      </div>
    </div>

  </div>

  <!-- Gallery full width below -->
  {(images.length > 0 || videos.length > 0) && (
    <Gallery images={images} videos={videos} projectId={projectId} />
  )}
</section>

<style>
.project-section {
  border-top: 1px solid var(--line);
  padding: clamp(40px, 5vw, 64px) 0 0;
  transition: border-color var(--transition);
}
.project-section:last-of-type { border-bottom: none; }

.ps-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 clamp(16px, 4vw, 64px);
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: clamp(32px, 4vw, 64px);
  align-items: start;
}

/* ── Left column: meta ── */
.ps-meta-block {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.ps-meta-row {
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding: 14px 0;
  border-bottom: 1px solid var(--line);
}
.ps-meta-row:first-child { padding-top: 0; }

.ps-meta-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
}

.ps-meta-value {
  font-size: 18px;
  font-weight: 700;
  color: var(--ink-1);
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.ps-meta-sem {
  font-size: 22px;
  font-family: var(--font-serif);
  font-style: italic;
  font-weight: 800;
}

.ps-meta-course {
  font-size: 15px;
  font-weight: 600;
  color: var(--ink-2);
  line-height: 1.4;
  letter-spacing: -0.01em;
}

.ps-meta-divider {
  height: 20px;
  border: none;
}

.ps-desc {
  font-size: 14px;
  line-height: 1.8;
  color: var(--ink-2);
}

/* ── Right column ── */
.ps-header {
  margin-bottom: 28px;
}

.ps-num {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  color: var(--ink-3);
  margin-bottom: 8px;
  font-variant-numeric: tabular-nums;
}

.ps-title {
  font-family: var(--font-serif);
  font-size: clamp(26px, 3.5vw, 38px);
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--ink-1);
  line-height: 1.1;
  margin: 0 0 14px;
}

/* Category tags – clickable filter buttons */
.ps-cats {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.cat-tag--filter {
  font-family: var(--font-sans);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  padding: 5px 13px;
  border-radius: 99px;
  background: var(--accent-bg);
  color: var(--accent);
  border: 1.5px solid color-mix(in srgb, var(--accent) 35%, transparent);
  white-space: nowrap;
  cursor: pointer;
  transition: background var(--transition), color var(--transition), border-color var(--transition), transform 0.12s;
}
.cat-tag--filter:hover {
  background: var(--accent);
  color: white;
  border-color: var(--accent);
}
.cat-tag--filter.active,
.cat-tag--filter[aria-pressed="true"] {
  background: var(--accent);
  color: white;
  border-color: var(--accent);
}
.cat-tag--filter:focus-visible {
  outline: var(--focus-ring);
  outline-offset: 2px;
}
.cat-tag--filter:active { transform: scale(0.96); }

/* Stack / tool tags – clickable filter buttons */
.ps-tools-row {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  padding-top: 1px;
}

.tool-tag--filter {
  font-family: var(--font-sans);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.05em;
  padding: 4px 11px;
  border-radius: 99px;
  background: var(--accent-2bg);
  color: var(--accent-2);
  border: 1.5px solid color-mix(in srgb, var(--accent-2) 30%, transparent);
  white-space: nowrap;
  cursor: pointer;
  transition: background var(--transition), color var(--transition), border-color var(--transition), transform 0.12s;
}
.tool-tag--filter:hover {
  background: var(--accent-2);
  color: white;
  border-color: var(--accent-2);
}
.tool-tag--filter.active,
.tool-tag--filter[aria-pressed="true"] {
  background: var(--accent-2);
  color: white;
  border-color: var(--accent-2);
}
.tool-tag--filter:focus-visible {
  outline: var(--focus-ring);
  outline-offset: 2px;
}
.tool-tag--filter:active { transform: scale(0.96); }

/* Attrs row */
.ps-attrs {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.ps-attr {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}
.ps-attr-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-3);
  min-width: 64px;
  padding-top: 3px;
  flex-shrink: 0;
}
.ps-contrib-list {
  font-size: 13px;
  color: var(--ink-2);
  padding-top: 2px;
}

/* Responsive */
@media (max-width: 900px) {
  .ps-inner {
    grid-template-columns: 1fr;
  }
  .ps-meta-block {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0 24px;
  }
  .ps-desc {
    grid-column: 1 / -1;
  }
  .ps-meta-divider { display: none; }
}
@media (max-width: 600px) {
  .ps-meta-block { display: flex; flex-direction: column; }
  .ps-num { display: none; }
}
</style>

<script>
// Make card-level category/tool tags act as global filters
document.addEventListener('click', e => {
  const catBtn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-filter-cat]');
  const toolBtn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-filter-tool]');

  if (catBtn) {
    const val = catBtn.dataset.filterCat!;
    // Trigger the global filter system
    window.__triggerFilter?.('category', val, catBtn);
  }
  if (toolBtn) {
    const val = toolBtn.dataset.filterTool!;
    window.__triggerFilter?.('tool', val, toolBtn);
  }
});
</script>
