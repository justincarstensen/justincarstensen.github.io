    ))}
  </main>

  <div class="empty-state" id="empty-state" role="status" aria-live="polite">
    <strong data-i18n="empty-title">Keine Projekte gefunden</strong>
    <span data-i18n="empty-sub">Filter oder Suche anpassen, um Ergebnisse zu sehen.</span>
