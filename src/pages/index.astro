---
<!DOCTYPE html>
<html lang="de" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Justin Carstensen — Portfolio</title>
  <meta name="description" content="UI Designer & Medieninformatik-Student an der Hochschule Flensburg." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Barlow+Condensed:wght@600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <!-- Skip to main content (WCAG 2.4.1) -->
  <a href="#main-content" class="skip-link" data-i18n="skip">Zum Hauptinhalt springen</a>

  <!-- Topbar -->
  <header class="topbar" role="banner">
    <div class="topbar-inner">
      <a href="#" class="logo" aria-label="Justin Carstensen – Portfolio Startseite">Justin Carstensen</a>
      <nav class="nav-right" aria-label="Hauptnavigation">
        <a href="#projekte" class="nav-link" data-i18n="nav-projects">Projekte</a>
        <button class="nav-cta" id="contact-btn" aria-haspopup="dialog" data-i18n="nav-contact">Kontakt</button>

        <!-- Language toggle -->
        <div class="lang-toggle" role="group" aria-label="Sprache wählen">
          <button class="lang-btn active" id="lang-de" aria-pressed="true" lang="de">DE</button>
          <button class="lang-btn" id="lang-en" aria-pressed="false" lang="en">EN</button>
        </div>

        <!-- Theme toggle -->
        <button class="theme-toggle" id="theme-toggle" aria-label="Farbschema wechseln" aria-live="polite">
          <span class="theme-toggle-thumb" aria-hidden="true">
            <svg class="sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            <svg class="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </span>
        </button>
      </nav>
    </div>
  </header>

  <!-- Contact Modal -->
  <div id="contact-modal" class="contact-modal" hidden role="dialog" aria-modal="true" aria-labelledby="contact-modal-title">
    <div class="contact-modal-bg" id="contact-modal-bg"></div>
    <div class="contact-modal-box">
      <button class="contact-close" id="contact-modal-close" aria-label="Schließen">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <h2 class="contact-modal-title" id="contact-modal-title" data-i18n="contact-title">Kontakt</h2>
      <p class="contact-modal-sub" data-i18n="contact-sub">Schreib mir gerne eine Mail. Ich freue mich auf deine Nachricht.</p>
      <div class="contact-email-row">
        <span class="contact-email-addr" id="contact-email-addr" aria-label="E-Mail-Adresse">hello@justin-carstensen.de</span>
        <button class="contact-copy-btn" id="contact-copy-btn" aria-live="polite" data-i18n="contact-copy">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          Kopieren
        </button>
      </div>
      <a class="contact-open-btn" id="contact-mail-link" href="mailto:hello@justin-carstensen.de" data-i18n="contact-open">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Mail-Client öffnen
      </a>
    </div>
  </div>

  <!-- Hero -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-eyebrow" aria-hidden="true">
      <span class="hero-eyebrow-dot"></span>
      <span data-i18n="hero-eyebrow">B.Sc. Medieninformatik · Hochschule Flensburg</span>
    </div>
    <div class="hero-grid">
      <div class="hero-left">
        <h1 class="hero-name" id="hero-heading">Justin<br /><em>Carstensen</em></h1>
        <p class="hero-sub" data-i18n="hero-sub">
          UI Designer mit Fokus auf Nutzererfahrung, visuelle Klarheit und interaktive Systeme.
          Ich gestalte von der ersten Skizze bis zum fertigen Interface — mit einem Sinn für Details, die zählen.
        </p>
      </div>
      <div class="hero-meta">
        <div class="hero-meta-item">
          <strong data-i18n="hero-meta-study">Studium</strong>
          <span data-i18n="hero-meta-university">Hochschule Flensburg</span>
        </div>
        <div class="hero-meta-item">
          <strong data-i18n="hero-meta-focus">Fokus</strong>
          <span data-i18n="hero-meta-focus-val">UI / UX Design</span>
        </div>
        <button class="hero-contact-btn" id="hero-contact-btn" aria-haspopup="dialog">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span data-i18n="hero-contact-btn">E-Mail schreiben</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Filter + Search bar -->
  <div class="filter-wrap" id="projekte">
    <div class="filter-inner" role="search" aria-label="Projekte filtern und suchen">
      <!-- Search -->
      <div class="search-wrap">
        <svg class="search-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input
          class="search-input"
          id="search-input"
          type="search"
          placeholder="Titel suchen…"
          aria-label="Nach Projekttitel suchen"
          autocomplete="off"
          data-i18n-placeholder="search-placeholder"
        />
      </div>

      <div class="filter-sep" aria-hidden="true"></div>

      <!-- Sort -->
      <select class="sort-select" id="sort-select" aria-label="Sortierung wählen">
        <option value="semester-desc" data-i18n="sort-sem-desc">Semester ↓</option>
        <option value="semester-asc" data-i18n="sort-sem-asc">Semester ↑</option>
        <option value="year-desc" data-i18n="sort-year-desc">Jahr ↓</option>
        <option value="year-asc" data-i18n="sort-year-asc">Jahr ↑</option>
      </select>

      <!-- Active filter chips area -->
      <div class="active-filters" id="active-filters" aria-label="Aktive Filter"></div>

      <span class="result-count" id="proj-count" aria-live="polite" aria-atomic="true">
        {projects.length} Projekte
      </span>
    </div>
  </div>

  <!-- Projects -->
  <main id="main-content" aria-label="Projektliste">
    {projects.map((project, i) => (
      <div class="project-item" style={`animation-delay:${i * 60}ms`} data-semester={project.semester} data-year={project.year}>
        <ProjectCard {...project} index={i} />
      </div>
    ))}
  </main>

  <div class="empty-state" id="empty-state" role="status" aria-live="polite">
    <strong data-i18n="empty-title">Keine Projekte gefunden</strong>
    <span data-i18n="empty-sub">Filter oder Suche anpassen, um Ergebnisse zu sehen.</span>
    <br />
    <button class="reset-btn" id="reset-btn" data-i18n="reset-btn">Filter zurücksetzen</button>
  </div>

  <!-- Footer -->
  <footer class="site-footer" role="contentinfo">
    <div class="footer-inner">
      <span class="footer-name">Justin Carstensen</span>
      <span class="footer-right" data-i18n="footer-right">B.Sc. Medieninformatik · Hochschule Flensburg</span>
    </div>
  </footer>

  <!-- Accessibility Panel -->
  <div class="a11y-knob" id="a11y-knob">
    <div
      class="a11y-panel"
      id="a11y-panel"
      role="dialog"
      aria-modal="false"
      aria-label="Barrierefreiheit-Einstellungen"
    >
      <div class="a11y-panel-header">
        <span class="a11y-panel-title">Barrierefreiheit</span>
        <button class="a11y-panel-reset" id="a11y-reset" type="button">Zurücksetzen</button>
      </div>
      <div class="a11y-panel-body">

        <!-- Vision -->
        <div class="a11y-section">
          <span class="a11y-section-label">Sehen</span>
          <div class="a11y-row">
            <div class="a11y-row-text">
              <span class="a11y-row-label" id="lbl-contrast">Hoher Kontrast</span>
              <span class="a11y-row-desc">Extrem Schwarz/Weiß, keine Farben</span>
            </div>
            <button class="a11y-switch" role="switch" id="a11y-contrast" aria-checked="false" aria-labelledby="lbl-contrast" type="button"></button>
          </div>
          <div class="a11y-row" style="margin-top:10px;">
            <span class="a11y-row-label" id="lbl-fontsize">Schriftgröße</span>
            <div class="a11y-btn-group" role="group" aria-labelledby="lbl-fontsize">
              <button class="a11y-opt-btn active" data-fontsize="normal" type="button">Normal</button>
              <button class="a11y-opt-btn" data-fontsize="large" type="button">Groß</button>
              <button class="a11y-opt-btn" data-fontsize="larger" type="button">Größer</button>
            </div>
          </div>
          <div class="a11y-row" style="margin-top:10px;">
            <div class="a11y-row-text">
              <span class="a11y-row-label" id="lbl-links">Links unterstreichen</span>
              <span class="a11y-row-desc">Alle Links mit Unterstrich</span>
            </div>
            <button class="a11y-switch" role="switch" id="a11y-links" aria-checked="false" aria-labelledby="lbl-links" type="button"></button>
          </div>
        </div>

        <!-- Motor / Lesbarkeit -->
        <div class="a11y-section">
          <span class="a11y-section-label">Motorik &amp; Lesbarkeit</span>
          <div class="a11y-row">
            <div class="a11y-row-text">
              <span class="a11y-row-label" id="lbl-motion">Animationen reduzieren</span>
              <span class="a11y-row-desc">Alle Transitions deaktivieren</span>
            </div>
            <button class="a11y-switch" role="switch" id="a11y-motion" aria-checked="false" aria-labelledby="lbl-motion" type="button"></button>
          </div>
          <div class="a11y-row" style="margin-top:8px;">
            <div class="a11y-row-text">
              <span class="a11y-row-label" id="lbl-dyslexia">Leseschrift (Legasthenie)</span>
              <span class="a11y-row-desc">Arial mit mehr Abstand</span>
            </div>
            <button class="a11y-switch" role="switch" id="a11y-dyslexia" aria-checked="false" aria-labelledby="lbl-dyslexia" type="button"></button>
          </div>
        </div>

      </div>
    </div>

    <button
      class="a11y-trigger"
      id="a11y-trigger"
      type="button"
      aria-expanded="false"
      aria-controls="a11y-panel"
      aria-label="Barrierefreiheit-Einstellungen öffnen"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="4" r="1.5" fill="currentColor" stroke="none"/>
        <path d="M7 8h10M12 8v12M8 12l-2 4M16 12l2 4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

  <script>
    // ── Accessibility Panel ──────────────────────────────────────────────
    (function() {
      const html = document.documentElement;
      const trigger = document.getElementById('a11y-trigger')!;
      const panel   = document.getElementById('a11y-panel')!;
      const PREFS_KEY = 'a11y-prefs';

      type Prefs = { contrast: boolean; fontsize: string; links: boolean; motion: boolean; dyslexia: boolean; };
      const defaults: Prefs = { contrast: false, fontsize: 'normal', links: false, motion: false, dyslexia: false };

      function loadPrefs(): Prefs {
        try { return { ...defaults, ...JSON.parse(localStorage.getItem(PREFS_KEY) || '{}') }; }
        catch { return { ...defaults }; }
      }
      function savePrefs(p: Prefs) { localStorage.setItem(PREFS_KEY, JSON.stringify(p)); }

      function setSwitch(id: string, val: boolean) {
        const btn = document.getElementById(id);
        if (btn) btn.setAttribute('aria-checked', val ? 'true' : 'false');
      }

      function applyPrefs(p: Prefs) {
        // High contrast
        if (p.contrast) html.setAttribute('data-contrast', 'high');
        else html.removeAttribute('data-contrast');

        // Font size
        if (p.fontsize && p.fontsize !== 'normal') html.setAttribute('data-fontsize', p.fontsize);
        else html.removeAttribute('data-fontsize');

        // Links
        if (p.links) html.setAttribute('data-links', 'underline');
        else html.removeAttribute('data-links');

        // Motion
        if (p.motion) html.setAttribute('data-motion', 'reduced');
        else html.removeAttribute('data-motion');

        // Dyslexia
        if (p.dyslexia) html.setAttribute('data-font', 'dyslexia');
        else html.removeAttribute('data-font');

        // Sync UI switches
        setSwitch('a11y-contrast', p.contrast);
        setSwitch('a11y-links',    p.links);
        setSwitch('a11y-motion',   p.motion);
        setSwitch('a11y-dyslexia', p.dyslexia);

        // Sync font size buttons
        document.querySelectorAll<HTMLButtonElement>('[data-fontsize]').forEach(btn => {
          btn.classList.toggle('active', btn.dataset.fontsize === p.fontsize);
        });
      }

      // ── Panel open/close ──────────────────────────────────────────────
      let isOpen = false;

      function openPanel() {
        isOpen = true;
        panel.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
      }
      function closePanel() {
        isOpen = false;
        panel.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
      }

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        isOpen ? closePanel() : openPanel();
      });

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (isOpen) {
          const knob = document.getElementById('a11y-knob')!;
          if (!knob.contains(e.target as Node)) closePanel();
        }
      });

      // Close on Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen) { closePanel(); trigger.focus(); }
      });

      // ── Switch buttons ──────────────────────────────────────────────
      let prefs = loadPrefs();

      function makeSwitch(id: string, key: keyof Prefs) {
        const btn = document.getElementById(id);
        if (!btn) return;
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          (prefs as any)[key] = !(prefs as any)[key];
          applyPrefs(prefs);
          savePrefs(prefs);
        });
      }

      makeSwitch('a11y-contrast', 'contrast');
      makeSwitch('a11y-links',    'links');
      makeSwitch('a11y-motion',   'motion');
      makeSwitch('a11y-dyslexia', 'dyslexia');

      // Font size buttons
      document.querySelectorAll<HTMLButtonElement>('[data-fontsize]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          prefs.fontsize = btn.dataset.fontsize!;
          applyPrefs(prefs);
          savePrefs(prefs);
        });
      });

      // Reset
      document.getElementById('a11y-reset')!.addEventListener('click', (e) => {
        e.stopPropagation();
        prefs = { ...defaults };
        applyPrefs(prefs);
        savePrefs(prefs);
      });

      // Auto-detect prefers-reduced-motion on first visit
      if (!localStorage.getItem(PREFS_KEY) && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        prefs.motion = true;
      }

      applyPrefs(prefs);
    })();
  </script>

  <script>
    // ── i18n ──────────────────────────────────────────────────────────────
    const TRANSLATIONS: Record<string, Record<string, string>> = {
      de: {
        skip: "Zum Hauptinhalt springen",
        "nav-projects": "Projekte",
        "nav-contact": "Kontakt",
        "hero-eyebrow": "B.Sc. Medieninformatik · Hochschule Flensburg",
        "hero-sub": "UI Designer mit Fokus auf Nutzererfahrung, visuelle Klarheit und interaktive Systeme. Ich gestalte von der ersten Skizze bis zum fertigen Interface — mit einem Sinn für Details, die zählen.",
        "hero-meta-study": "Studium",
        "hero-meta-university": "Hochschule Flensburg",
        "hero-meta-focus": "Fokus",
        "hero-meta-focus-val": "UI / UX Design",
        "hero-contact-btn": "E-Mail schreiben",
        "contact-title": "Kontakt",
        "contact-sub": "Schreib mir gerne eine Mail. Ich freue mich auf deine Nachricht.",
        "contact-copy": "Kopieren",
        "contact-copied": "Kopiert!",
        "contact-open": "Mail-Client öffnen",
        "filter-cat": "Kategorie",
        "filter-stack": "Stack",
        "search-placeholder": "Titel suchen…",
        "sort-sem-desc": "Semester ↓",
        "sort-sem-asc": "Semester ↑",
        "sort-year-desc": "Jahr ↓",
        "sort-year-asc": "Jahr ↑",
        "empty-title": "Keine Projekte gefunden",
        "empty-sub": "Filter oder Suche anpassen, um Ergebnisse zu sehen.",
        "reset-btn": "Filter zurücksetzen",
        "footer-right": "B.Sc. Medieninformatik · Hochschule Flensburg",
        "theme-toggle-to-dark": "Zu Dunkel-Modus wechseln",
        "theme-toggle-to-light": "Zu Hell-Modus wechseln",
        "close-contact": "Schließen",
        "project-count-singular": "Projekt",
        "project-count-plural": "Projekte",
        "contact-close-label": "Kontaktfenster schließen",
      },
      en: {
        skip: "Skip to main content",
        "nav-projects": "Projects",
        "nav-contact": "Contact",
        "hero-eyebrow": "B.Sc. Media Informatics · Flensburg University",
        "hero-sub": "UI Designer focused on user experience, visual clarity, and interactive systems. I design from the first sketch to the finished interface — with an eye for details that matter.",
        "hero-meta-study": "Studies",
        "hero-meta-university": "Flensburg University",
        "hero-meta-focus": "Focus",
        "hero-meta-focus-val": "UI / UX Design",
        "hero-contact-btn": "Send an email",
        "contact-title": "Contact",
        "contact-sub": "Feel free to send me an email. I look forward to hearing from you.",
        "contact-copy": "Copy",
        "contact-copied": "Copied!",
        "contact-open": "Open mail client",
        "filter-cat": "Category",
        "filter-stack": "Stack",
        "search-placeholder": "Search by title…",
        "sort-sem-desc": "Semester ↓",
        "sort-sem-asc": "Semester ↑",
        "sort-year-desc": "Year ↓",
        "sort-year-asc": "Year ↑",
        "empty-title": "No projects found",
        "empty-sub": "Adjust filters or search to see results.",
        "reset-btn": "Reset filters",
        "footer-right": "B.Sc. Media Informatics · Flensburg University",
        "theme-toggle-to-dark": "Switch to dark mode",
        "theme-toggle-to-light": "Switch to light mode",
        "close-contact": "Close",
        "project-count-singular": "project",
        "project-count-plural": "projects",
        "contact-close-label": "Close contact window",
      },
    };

    let currentLang = localStorage.getItem('lang') || 'de';

    function applyLang(lang: string) {
      currentLang = lang;
      localStorage.setItem('lang', lang);
      document.documentElement.lang = lang;

      const t = TRANSLATIONS[lang];

      // Text elements
      document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
        const key = el.dataset.i18n!;
        if (t[key]) el.textContent = t[key];
      });

      // Placeholders
      document.querySelectorAll<HTMLInputElement>('[data-i18n-placeholder]').forEach(el => {
        const key = el.dataset.i18nPlaceholder!;
        if (t[key]) el.placeholder = t[key];
      });

      // Sort options
      document.querySelectorAll<HTMLOptionElement>('[data-i18n]').forEach(el => {
        if (el.tagName === 'OPTION') {
          const key = el.dataset.i18n!;
          if (t[key]) el.textContent = t[key];
        }
      });

      // Lang buttons
      const deBtn = document.getElementById('lang-de')!;
      const enBtn = document.getElementById('lang-en')!;
      deBtn.classList.toggle('active', lang === 'de');
      enBtn.classList.toggle('active', lang === 'en');
      deBtn.setAttribute('aria-pressed', lang === 'de' ? 'true' : 'false');
      enBtn.setAttribute('aria-pressed', lang === 'en' ? 'true' : 'false');

      // Update count label
      updateCount();
    }

    document.getElementById('lang-de')!.addEventListener('click', () => applyLang('de'));
    document.getElementById('lang-en')!.addEventListener('click', () => applyLang('en'));

    // ── Theme ──────────────────────────────────────────────────────────────
    const root = document.documentElement;
    const themeBtn = document.getElementById('theme-toggle')!;

    function getSystemTheme() {
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    const storedTheme = localStorage.getItem('theme');
    root.setAttribute('data-theme', storedTheme || 'light');

    themeBtn.addEventListener('click', () => {
      const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      const t = TRANSLATIONS[currentLang];
      themeBtn.setAttribute('aria-label', next === 'dark' ? t['theme-toggle-to-light'] : t['theme-toggle-to-dark']);
    });

    // ── Contact modal ──────────────────────────────────────────────────────
    const modal = document.getElementById('contact-modal')!;
    const modalClose = document.getElementById('contact-modal-close')!;
    const modalBg = document.getElementById('contact-modal-bg')!;
    const copyBtn = document.getElementById('contact-copy-btn')!;
    const EMAIL = 'hello@justin-carstensen.de';

    let lastFocused: HTMLElement | null = null;

    function openModal() {
      lastFocused = document.activeElement as HTMLElement;
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      // Focus first interactive element
      setTimeout(() => modalClose.focus(), 50);
      trapFocus(modal);
    }

    function closeModal() {
      modal.hidden = true;
      document.body.style.overflow = '';
      lastFocused?.focus();
    }

    // Focus trap inside modal (WCAG 2.1.2)
    function trapFocus(el: HTMLElement) {
      const focusable = el.querySelectorAll<HTMLElement>(
        'button, a[href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
      );
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      const handler = (e: KeyboardEvent) => {
        if (e.key !== 'Tab') return;
        if (e.shiftKey ? document.activeElement === first : document.activeElement === last) {
          e.preventDefault();
          (e.shiftKey ? last : first).focus();
        }
      };
      el.addEventListener('keydown', handler);
    }

    document.getElementById('contact-btn')!.addEventListener('click', openModal);
    document.getElementById('hero-contact-btn')!.addEventListener('click', openModal);
    modalClose.addEventListener('click', closeModal);
    modalBg.addEventListener('click', closeModal);
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && !modal.hidden) closeModal(); });

    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(EMAIL);
        const t = TRANSLATIONS[currentLang];
        copyBtn.classList.add('copied');
        copyBtn.textContent = t['contact-copied'];
        setTimeout(() => {
          copyBtn.classList.remove('copied');
          const icon = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
          copyBtn.innerHTML = icon + ' ' + t['contact-copy'];
        }, 2000);
      } catch {
        // fallback: select text
        const range = document.createRange();
        const addr = document.getElementById('contact-email-addr')!;
        range.selectNode(addr);
        window.getSelection()?.removeAllRanges();
        window.getSelection()?.addRange(range);
      }
    });

    // ── Filter + Search + Sort ─────────────────────────────────────────────
    const items = Array.from(document.querySelectorAll<HTMLElement>('.project-item'));
    const countEl = document.getElementById('proj-count')!;
    const emptyEl = document.getElementById('empty-state')!;
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
    const mainEl = document.getElementById('main-content')!;
    const resetBtn = document.getElementById('reset-btn')!;
    const activeFiltersEl = document.getElementById('active-filters')!;

    let activeCats = new Set<string>();
    let activeTools = new Set<string>();

    function syncCardTags() {
      // Sync category tags on all project cards
      document.querySelectorAll<HTMLElement>('[data-filter-cat]').forEach(btn => {
        const val = btn.dataset.filterCat!;
        const isActive = activeCats.has(val);
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-pressed', isActive.toString());
      });
      // Sync tool tags on all project cards
      document.querySelectorAll<HTMLElement>('[data-filter-tool]').forEach(btn => {
        const val = btn.dataset.filterTool!;
        const isActive = activeTools.has(val);
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-pressed', isActive.toString());
      });
    }

    function renderChips() {
      activeFiltersEl.innerHTML = '';
      const mkChip = (type: string, val: string) => {
        const chip = document.createElement('button');
        chip.className = 'active-filter-chip';
        chip.dataset.chipType = type;
        chip.type = 'button';
        chip.innerHTML = val + ' <span class="chip-x" aria-hidden="true"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span>';
        chip.setAttribute('aria-label', `Filter '${val}" entfernen`);
        chip.addEventListener('click', () => {
          if (type === 'category') activeCats.delete(val);
          else activeTools.delete(val);
          syncCardTags();
          renderChips();
          filterAndSort();
        });
        activeFiltersEl.appendChild(chip);
      };
      activeCats.forEach(v => mkChip('category', v));
      activeTools.forEach(v => mkChip('tool', v));
    }

    // Global trigger function used by ProjectCard tags
    (window as any).__triggerFilter = function(type: string, val: string, _btn: HTMLElement) {
      const set = type === 'category' ? activeCats : activeTools;
      if (set.has(val)) set.delete(val);
      else set.add(val);
      syncCardTags();
      renderChips();
      filterAndSort();
      // Scroll to filter bar
      document.getElementById('projekte')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    searchInput.addEventListener('input', filterAndSort);
    sortSelect.addEventListener('change', filterAndSort);

    resetBtn.addEventListener('click', () => {
      activeCats.clear();
      activeTools.clear();
      searchInput.value = '';
      sortSelect.value = 'semester-desc';
      syncCardTags();
      renderChips();
      filterAndSort();
    });

    function updateCount() {
      const visible = items.filter(i => !i.classList.contains('hidden')).length;
      const t = TRANSLATIONS[currentLang];
      const word = visible === 1 ? t['project-count-singular'] : t['project-count-plural'];
      countEl.textContent = `${visible} ${word}`;
    }

    function filterAndSort() {
      const query = searchInput.value.toLowerCase().trim();

      // Filter
      items.forEach(item => {
        const el = item.querySelector<HTMLElement>('[data-categories]')!;
        const titleEl = item.querySelector<HTMLElement>('.ps-title');
        const cats: string[] = JSON.parse(el.dataset.categories || '[]');
        const tools: string[] = JSON.parse(el.dataset.tools || '[]');
        const title = (titleEl?.textContent || '').toLowerCase();

        const catOk = activeCats.size === 0 || [...activeCats].some(c => cats.includes(c));
        const toolOk = activeTools.size === 0 || [...activeTools].some(t => tools.includes(t));
        const searchOk = !query || title.includes(query);

        item.classList.toggle('hidden', !(catOk && toolOk && searchOk));
      });

      // Sort
      const sortVal = sortSelect.value;
      const visible = items.filter(i => !i.classList.contains('hidden'));
      visible.sort((a, b) => {
        const semA = parseInt(a.dataset.semester || '0');
        const semB = parseInt(b.dataset.semester || '0');
        const yearA = parseInt(a.dataset.year || '0');
        const yearB = parseInt(b.dataset.year || '0');
        if (sortVal === 'semester-desc') return semB - semA;
        if (sortVal === 'semester-asc') return semA - semB;
        if (sortVal === 'year-desc') return yearB - yearA;
        if (sortVal === 'year-asc') return yearA - yearB;
        return 0;
      });

      // Re-append in sorted order
      visible.forEach(el => mainEl.appendChild(el));
      items.filter(i => i.classList.contains('hidden')).forEach(el => mainEl.appendChild(el));

      const n = visible.length;
      emptyEl.style.display = n === 0 ? 'block' : 'none';
      updateCount();
    }

    // ── Init ───────────────────────────────────────────────────────────────
    applyLang(currentLang);
    filterAndSort();
  </script>
</body>
